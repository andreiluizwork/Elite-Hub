    <!-- SCRIPT DE BUSCA E UX -->
    <script>
        function executarBusca() {
            const input = document.getElementById('mainSearch');
            const query = input.value.trim();
            
            if(query !== "") {
                const formattedQuery = query.replace(/\s+/g, "-");
                window.open(`https://lista.mercadolivre.com.br/${formattedQuery}`, '_blank');
                input.value = ''; // Limpa após a busca
            } else {
                // Efeito de "Tremer" e borda vermelha se a busca for vazia
                input.classList.add('border-red-500', 'animate-pulse');
                setTimeout(() => {
                    input.classList.remove('border-red-500', 'animate-pulse');
                }, 1000);
            }
        }

        document.getElementById('mainSearch').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                executarBusca();
            }
        });
    </script>
