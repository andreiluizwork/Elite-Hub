        /* Glassmorphism Refinado */
        .glass { 
            background: rgba(15, 15, 20, 0.6); 
            backdrop-filter: blur(16px); 
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255,255,255,0.05); 
        }
        
        /* Efeito de Card Premium */
        .card-glow { transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
        .card-glow:hover { 
            border-color: rgba(0, 114, 206, 0.5); 
            box-shadow: 0 10px 40px -10px rgba(0, 114, 206, 0.3); 
            transform: translateY(-4px); 
        }

        /* Botão com efeito de Brilho (Shine) */
        .btn-gradient { 
            background: linear-gradient(90deg, #005ba6, #00b4ff, #005ba6); 
            background-size: 200% auto;
            transition: 0.5s; 
        }
        .btn-gradient:hover { 
            background-position: right center;
            box-shadow: 0 0 20px rgba(0, 180, 255, 0.5);
            transform: scale(1.02);
        }

        /* Badge Pulsante Moderno */
        .badge-live { 
            position: absolute; top: 1rem; right: 1rem; 
            background: linear-gradient(45deg, #ef4444, #b91c1c); 
            padding: 4px 14px; border-radius: 20px; 
            font-size: 0.7rem; font-weight: 800; letter-spacing: 1px;
            box-shadow: 0 0 15px rgba(239, 68, 68, 0.4);
            animation: pulse-red 2s infinite; 
            z-index: 10;
        }
        @keyframes pulse-red { 
            0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); } 
            70% { box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); } 
            100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); } 
        }

        /* Efeito Menu Gamer nos Links */
        .link-hover-effect:hover {
            transform: translateX(8px);
            background: rgba(255,255,255,0.1);
            border-left-color: var(--ps-blue);
        }
    </style>
</head>
